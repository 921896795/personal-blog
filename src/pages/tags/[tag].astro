---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { getAllTags, getPublishedPosts } from "@/utils/posts";

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map(({ tag }) => ({
    params: { tag: encodeURIComponent(tag) },
    props: { tag }
  }));
}

const { tag } = Astro.props;
const posts = (await getPublishedPosts()).filter(post => post.data.tags.includes(tag));
---

<BaseLayout title={`标签：${tag}`} description={`标签 ${tag} 下的文章`}>
  <section class="container">
    <p class="eyebrow">Tag</p>
    <h1>#{tag}</h1>
    <p class="lead">这个标签下共有 {posts.length} 篇文章。</p>
  </section>
  <section class="container section post-list">
    {posts.map(post => <PostCard post={post} />)}
  </section>
</BaseLayout>
